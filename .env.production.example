# Creative Commerce — Production Environment
# Copy to .env.production and fill in values

# Database
DB_USER=creative_commerce
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=creative_commerce

# Auth (generate with: openssl rand -hex 32)
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# Ollama AI (running on host machine)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
